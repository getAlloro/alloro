{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "alloro-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true,
      "cwd": "frontend"
    },
    {
      "name": "alloro-docs",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5176,
      "autoPort": true,
      "cwd": "docs"
    },
    {
      "name": "api",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:api"],
      "port": 3000
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:web"],
      "port": 5174
    }
  ]
}
