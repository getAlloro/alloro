{
  "name": "signalsai-backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n api,worker,web -c blue,yellow,green \"npm:dev:api\" \"npm:dev:worker\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/workers/worker.ts",
    "dev:web": "npm --prefix frontend run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:conventions": "bash scripts/check-conventions.sh",
    "audit:constitution": "bash scripts/check-conventions.sh --audit",
    "lint": "eslint src",
    "depcruise": "depcruise src",
    "check:all": "npm run check:conventions; npm run lint; npm --prefix frontend run lint; npm run depcruise",
    "build": "tsc && rsync -a --include='*/' --include='*.md' --exclude='*' src/agents/ dist/agents/",
    "start": "node dist/index.js",
    "db:migrate": "knex migrate:latest",
    "db:rollback": "knex migrate:rollback",
    "db:seed": "knex seed:run",
    "db:make-migration": "knex migrate:make",
    "db:make-seed": "knex seed:make"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.9",
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@google/genai": "^1.43.0",
    "@googleapis/businessprofileperformance": "^3.0.1",
    "@googleapis/mybusinessaccountmanagement": "^5.0.1",
    "@googleapis/mybusinessbusinesscalls": "^6.0.1",
    "@googleapis/mybusinessbusinessinformation": "^6.1.0",
    "@sentry/node": "^10.39.0",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.0",
    "@types/sanitize-html": "^2.16.0",
    "archiver": "^7.0.1",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.1",
    "cheerio": "^1.2.0",
    "cron-parser": "^5.5.0",
    "csv-parser": "^3.2.0",
    "csvtojson": "^2.0.10",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^159.0.0",
    "graphql-request": "^7.2.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mammoth": "^1.12.0",
    "multer": "^2.0.2",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.3",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer": "^24.34.0",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.5",
    "stripe": "^20.4.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2",
    "unzipper": "^0.12.3",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/supertest": "7.2.0",
    "@types/unzipper": "^0.10.11",
    "@types/uuid": "^9.0.8",
    "@types/xlsx": "^0.0.36",
    "concurrently": "^9.2.3",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "pino-pretty": "13.1.3",
    "supertest": "7.2.2",
    "ts-morph": "27.0.0",
    "tsx": "^4.20.6",
    "typescript-eslint": "^8.61.0",
    "vitest": "4.1.8"
  }
}
