{
    on_demand_tls {
        ask http://localhost:7777/verify-domain
    }
}

https:// {
    log {
        output file /var/log/caddy/access.log {
            roll_size 100MiB
            roll_keep 10
        }
        format json
    }
    tls {
        on_demand
    }
    reverse_proxy localhost:7777
}
